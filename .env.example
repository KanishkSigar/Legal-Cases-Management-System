# Copy this file to ".env" and fill in real values.

# --- Django ---
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# --- Database -------------------------------------------------------------
# Option A (production / one connection string). Takes priority if set:
# DATABASE_URL=mysql://user:password@host:3306/legal_cms
# DB_SSL_REQUIRE=True

# Option B (local): zero-config SQLite — no DB server needed:
DB_ENGINE=sqlite

# Option C (local MySQL): set DB_ENGINE=mysql and fill these:
# DB_ENGINE=mysql
# DB_NAME=legal_cms
# DB_USER=root
# DB_PASSWORD=your-mysql-password
# DB_HOST=127.0.0.1
# DB_PORT=3306

# --- First admin (used by `python manage.py createadmin`) -----------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe@123
ADMIN_EMAIL=admin@legalcms.local

# --- Production extras (optional) -----------------------------------------
# CSRF_TRUSTED_ORIGINS=https://your-project.vercel.app
# EXTRA_ALLOWED_HOSTS=your-project.vercel.app
